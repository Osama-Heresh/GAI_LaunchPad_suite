# Business LaunchPad Suite Environment Variables Config
# AI Studio automatically parses this file and displays fields in the Secrets panel,
# allowing you to safely enter and manage your API keys and production secrets.

# --- App Configuration ---
# The URL where this applet is hosted (automatically set by AI Studio at runtime)
APP_URL="MY_APP_URL"

# --- Supabase Database Configuration ---
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# --- AI Integration Keys (Optional fallbacks / system trial keys) ---
VITE_OPENAI_API_KEY=""
VITE_REPLICATE_API_KEY=""
VITE_STABILITY_API_KEY=""
VITE_RUNWAY_API_KEY=""
